{
  "name": "email-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Daily email triage + AI digest to Telegram. Runs on Mac mini via launchd.",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/run.js",
    "dev": "tsx src/run.ts",
    "dry-run": "tsx src/run.ts --dry-run",
    "test-connection": "tsx src/run.ts --test-connection"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "better-sqlite3": "^12.9.0",
    "dotenv": "^17.3.0",
    "imapflow": "^1.3.2",
    "mailparser": "^3.9.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/mailparser": "^3.4.6",
    "@types/node": "^22.10.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.0"
  }
}

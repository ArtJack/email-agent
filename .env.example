# ==========================================
# Email Agent — Environment Configuration
# ==========================================
# Copy this file to .env and fill in your real values.
# Never commit .env (it is in .gitignore).

# --- Claude API ---
# Get a key at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# --- Yahoo Mail (IMAP) ---
# 1. Enable 2-Step Verification on your Yahoo account
# 2. Generate an App Password at https://login.yahoo.com/account/security
# 3. Paste the 16-character password below (no spaces)
YAHOO_USER=your.email@yahoo.com
YAHOO_APP_PASSWORD=your16charapppassword

# --- Telegram ---
# 1. Message @BotFather on Telegram -> /newbot -> save the HTTP API token
# 2. Send any message to your new bot from your personal Telegram account
# 3. Either message @userinfobot for your chat ID,
#    or visit https://api.telegram.org/bot<TOKEN>/getUpdates and copy "chat":{"id":...}
TELEGRAM_BOT_TOKEN=123456789:AA...
TELEGRAM_CHAT_ID=123456789

# --- Models (override to tune cost/quality) ---
# Triage + generic summaries: cheap classifier work
TRIAGE_MODEL=claude-haiku-4-5-20251001
SUMMARY_MODEL=claude-haiku-4-5-20251001

# Barron's premium sender (barronsstats@) — weekly deep analysis, worth the top model
BARRONS_PREMIUM_MODEL=claude-opus-4-7

# Barron's daily sender (access@) — frequent; one-sentence compression only
BARRONS_DAILY_MODEL=claude-haiku-4-5-20251001

# --- Behavior ---
# How far back to look on each run (hours). 26h gives 2h overlap safety across daily runs.
LOOKBACK_HOURS=26
# Timezone for the digest date header
TZ=America/New_York

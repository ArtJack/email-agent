# Copy this file to .env and fill in your own values.
# .env is gitignored.

# Claude API key — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-...

# IMAP credentials. Defaults to Yahoo; change IMAP_HOST/PORT for Gmail, Fastmail, etc.
# For Yahoo: enable 2-step verification, then generate an App Password
# at https://login.yahoo.com/account/security and paste it below (16 chars, no spaces).
IMAP_HOST=imap.mail.yahoo.com
IMAP_PORT=993
IMAP_USER=your.email@example.com
IMAP_PASSWORD=your_app_password

# Telegram — create a bot with @BotFather, then message it once from your account
# so you can look up your chat ID via @userinfobot.
TELEGRAM_BOT_TOKEN=123456789:AA...
TELEGRAM_CHAT_ID=123456789

# Optional: override the Claude models (defaults are Haiku for both — cheap)
TRIAGE_MODEL=claude-haiku-4-5-20251001
SUMMARY_MODEL=claude-haiku-4-5-20251001

# How far back to look on each run (hours). 26h gives a little overlap between daily runs.
LOOKBACK_HOURS=26

# Timezone for the date header in the digest
TZ=America/New_York
